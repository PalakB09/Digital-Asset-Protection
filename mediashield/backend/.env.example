# Copy this file to `.env` in the same folder (backend/) and set real values.
# Never commit `.env`.

# Google Gemini API key (AI Studio: https://aistudio.google.com/apikey)
# Used for AI discovery keywords on asset registration (image / video / URL).
GEMINI_API_KEY=

# Optional: Hugging Face token — higher rate limits when downloading CLIP weights
# HF_TOKEN=

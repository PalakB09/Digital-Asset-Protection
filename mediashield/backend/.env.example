# Copy this file to `.env` in the same folder (backend/) and set real values.
# Never commit `.env`.

# Google Gemini API key (AI Studio: https://aistudio.google.com/apikey)
# Used for AI discovery keywords on asset registration (image / video / URL).
GEMINI_API_KEY=

# Optional: Hugging Face token — higher rate limits when downloading CLIP weights
# HF_TOKEN=

# --- Telegram (Telethon — user account; see ../TELEGRAM_SETUP.md) ---
# Get api_id / api_hash from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# International format, e.g. +9198xxxxxxx
TELEGRAM_PHONE=
# Session file base name (stored under storage/telegram/)
TELEGRAM_SESSION_NAME=mediashield
# Skip Telegram files larger than this (megabytes)
TELEGRAM_MAX_DOWNLOAD_MB=50

# Copy this file to `.env` in the same folder (backend/) and set real values.
# Never commit `.env`.

# Google Gemini API key (AI Studio: https://aistudio.google.com/apikey)
# Used for AI discovery keywords on asset registration (image / video / URL).
GEMINI_API_KEY=

# Optional: Hugging Face token — higher rate limits when downloading CLIP weights
# HF_TOKEN=

# --- X / Twitter scraping auth (Playwright) ---
# Option A (recommended): persistent browser profile dir (stores cookies/session automatically)
# X_PLAYWRIGHT_USER_DATA_DIR=/absolute/path/to/backend/.playwright_x_profile
# Option B: one-time exported storage_state JSON
# X_PLAYWRIGHT_STORAGE_STATE=/absolute/path/to/backend/x_state.json

# --- Telegram (Telethon — user account; see ../TELEGRAM_SETUP.md) ---
# Get api_id / api_hash from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# International format, e.g. +9198xxxxxxx
TELEGRAM_PHONE=
# Session file base name (stored under storage/telegram/)
TELEGRAM_SESSION_NAME=mediashield
# Skip Telegram files larger than this (megabytes)
TELEGRAM_MAX_DOWNLOAD_MB=50

# --- Deployment / CORS ---
# Comma-separated list of allowed frontend origins.
# Example: https://mediashield-frontend-xxxxx-uc.a.run.app
# CORS_ORIGINS=

# Optional single frontend URL if you prefer setting one origin only.
# FRONTEND_URL=

# Optional Redis for durable queue on Cloud Run (recommended)
# REDIS_URL=redis://host:6379
